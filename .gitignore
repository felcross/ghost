# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mimocode
.mimocode/

# Raw source images — ignore everything in brand folders, un-ignore only optimized/
public/bento-grid/*
!public/bento-grid/optimized/

public/fila/*
!public/fila/optimized/

public/live/*
!public/live/optimized/

public/mercedes/*
!public/mercedes/optimized/

public/mercedes-vans/*

public/new-balance/*
!public/new-balance/optimized/

public/original-penguin/*
!public/original-penguin/optimized/

# Other raw/backup folders
public/Por Que Nos Escolher/
public/data copy/
